#!/usr/bin/env python3

"""
OpenShell Agent Builder

Compila el agente utilizando PyInstaller e incluye el
paquete bootstrap dentro del ejecutable.
"""

from pathlib import Path
import os
import shutil
import subprocess
import sys
import json


# =========================================================
# CONSTANTS
# =========================================================

PROJECT_ROOT = Path(__file__).parent.resolve()

ENTRYPOINT = PROJECT_ROOT / "agent"

BOOTSTRAP = PROJECT_ROOT / "bootstrap"

PASSPORTS_FILE = BOOTSTRAP / "passports.json"

DIST = PROJECT_ROOT / "dist"

BUILD = PROJECT_ROOT / "build"

SPEC = PROJECT_ROOT / "__pycache__"

PROGRAM_NAME = "agent"


# =========================================================
# HELPERS
# =========================================================

def separator() -> str:
    """
    PyInstaller utiliza:

    Linux/macOS:
        source:destination

    Windows:
        source;destination
    """

    return ";" if os.name == "nt" else ":"


def clean() -> None:

    print("[BUILD] Cleaning previous build...")

    shutil.rmtree(BUILD, ignore_errors=True)
    shutil.rmtree(DIST, ignore_errors=True)

    spec = PROJECT_ROOT / f"{PROGRAM_NAME}.spec"

    if spec.exists():
        spec.unlink()


# =========================================================
# VALIDATION
# =========================================================

def validate() -> None:

    if not ENTRYPOINT.exists():
        raise FileNotFoundError(
            f"Entrypoint not found: {ENTRYPOINT}"
        )

    if not BOOTSTRAP.exists():
        raise FileNotFoundError(
            f"Bootstrap directory not found: {BOOTSTRAP}"
        )

    print("[BUILD] Validation successful")


# =========================================================
# PREPARE
# =========================================================

# =========================================================
# PREPARE
# =========================================================

def prepare() -> None:
    """
    Prepare bootstrap resources.

    Requests one or more SECURITY_CODE values from the
    operator and generates:

        bootstrap/passports.json

    Finish with CTRL+C.
    """

    print()
    print("[PREPARE] Bootstrap preparation")
    print("[PREPARE] Enter SECURITY_CODE values.")
    print("[PREPARE] Press CTRL+C when finished.")
    print()

    passports = []

    try:

        while True:

            security_code = input(
                "SECURITY_CODE: "
            ).strip()

            if not security_code:
                continue

            passports.append(
                {
                    "security_code": security_code
                }
            )

    except KeyboardInterrupt:

        print()

    data = {
        "passports": passports
    }

    BOOTSTRAP.mkdir(
        parents=True,
        exist_ok=True
    )

    with open(
        PASSPORTS_FILE,
        "w",
        encoding="utf-8"
    ) as file:

        json.dump(
            data,
            file,
            indent=4
        )

    print(
        f"[PREPARE] {len(passports)} passport(s) generated."
    )

    print(
        f"[PREPARE] Output: {PASSPORTS_FILE}"
    )

    print()

# =========================================================
# BUILD
# =========================================================

def compile() -> None:

    add_data = (
        f"{BOOTSTRAP}"
        f"{separator()}"
        "bootstrap"
    )

    command = [

        sys.executable,

        "-m",

        "PyInstaller",

        "--clean",

        "--noconfirm",

        "--onefile",

        "--name",
        PROGRAM_NAME,

        "--distpath",
        str(DIST),

        "--workpath",
        str(BUILD),

        "--add-data",
        add_data,

        str(ENTRYPOINT),

        "--hidden-import",
        "platformdirs",

        "--hidden-import",
        "fsresource_tree"
    ]

    print("[BUILD] Executing:")

    print(" ".join(command))

    subprocess.run(
        command,
        check=True
    )


# =========================================================
# MAIN
# =========================================================

def main():

    print("----------------------------------------")
    print("OpenShell Agent Builder")
    print("----------------------------------------")

    validate()

    clean()

    prepare()
    
    compile()

    print()

    print("[BUILD] Build completed successfully.")

    print(
        f"[BUILD] Executable: "
        f"{DIST / PROGRAM_NAME}"
    )


if __name__ == "__main__":
    main()